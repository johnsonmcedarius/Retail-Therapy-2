local PathfindingService = game:GetService("PathfindingService")
local CollectionService = game:GetService("CollectionService")
local cachedModules = require(script.Parent.Parent.Server.CachedModules)

local CustomerService = {}

-- ==========================================
-- CUSTOMER STATES
-- ==========================================
CustomerService.States = {
	Spawning = "Spawning",
	Browsing = "Browsing",
	WalkingToRegister = "WalkingToRegister",
	WaitingInLine = "WaitingInLine",
	CheckingOut = "CheckingOut",
	Leaving = "Leaving",
}

local function moveToPosition(npc: Model, targetPosition: Vector3): boolean
	local humanoid = npc:FindFirstChildOfClass("Humanoid")
	if not humanoid then return false end

	local hrp = npc:FindFirstChild("HumanoidRootPart")
	if not hrp then return false end

	local path = PathfindingService:CreatePath({
		AgentRadius = 2,
		AgentHeight = 5,
		AgentCanJump = true,
		AgentJumpHeight = 10,
		AgentMaxSlope = 45,
	})

	local success, err = pcall(function()
		path:ComputeAsync(hrp.Position, targetPosition)
	end)

	if not success or path.Status ~= Enum.PathStatus.Success then
		-- Fallback: direct MoveTo if pathfinding fails
		humanoid:MoveTo(targetPosition)
		humanoid.MoveToFinished:Wait()
		return true
	end

	local waypoints = path:GetWaypoints()
	for _, waypoint in ipairs(waypoints) do
		-- Abort if NPC is destroyed or dead
		if not npc.Parent or not humanoid.Parent then return false end
		if humanoid.Health <= 0 then return false end

		if waypoint.Action == Enum.PathWaypointAction.Jump then
			humanoid.Jump = true
		end
		humanoid:MoveTo(waypoint.Position)
		humanoid.MoveToFinished:Wait()
	end

	return true
end

-- ==========================================
-- RACK INTERACTION
-- ==========================================

-- Find the interaction part on a rack model
-- Supports both "RackInteractionPart" (user's naming) and "InteractionPart" (existing racks)
local function getRackInteractionPart(rackModel: Model): BasePart?
	return rackModel:FindFirstChild("RackInteractionPart") or rackModel:FindFirstChild("InteractionPart")
end

-- Find racks that are not being browsed and have stock
local function findAvailableRacks(racks: {Model}): {Model}
	local available = {}
	for _, rack in ipairs(racks) do
		if rack:GetAttribute("BeingBrowsed") ~= true and (rack:GetAttribute("CurrentStock") or 0) > 0 then
			table.insert(available, rack)
		end
	end
	return available
end

-- Browse a rack: walk to it, browse, decide items to buy
-- NO payout calculation here - payout is calculated at checkout (delayed payout)
-- Returns: rackModel, itemsBought
local function browseRack(npc: Model, rackModel: Model): (Model?, number)
	local interactionPart = getRackInteractionPart(rackModel)
	if not interactionPart then return nil, 0 end

	-- Mark rack as being browsed (single-browser cap)
	rackModel:SetAttribute("BeingBrowsed", true)

	-- Walk to the rack interaction part
	local success = moveToPosition(npc, interactionPart.Position)
	if not success then
		rackModel:SetAttribute("BeingBrowsed", false)
		return nil, 0
	end

	-- Simulate browsing (wait for a random amount of time)
	-- TODO: Play browsing animation here when animation assets are available
	local browseTime = math.random(3, 8)
	task.wait(browseTime)

	-- Determine how many items to buy based on customer type
	local customerAIService = cachedModules.Cache.CustomerAIService
	local isVIP = npc:GetAttribute("IsVIP") == true
	local typeConfig = customerAIService and customerAIService.getCustomerTypeConfig(isVIP) or { MaxItems = 1 }

	-- Can't buy more than what's in stock
	local currentStock = rackModel:GetAttribute("CurrentStock") or 0
	local itemsBought = math.min(math.random(1, typeConfig.MaxItems), currentStock)

	-- Deduct stock from the rack
	if itemsBought > 0 then
		rackModel:SetAttribute("CurrentStock", currentStock - itemsBought)
	end

	-- Release the rack (no longer being browsed - heading to checkout)
	rackModel:SetAttribute("BeingBrowsed", false)

	return rackModel, itemsBought
end

-- ==========================================
-- CHECKOUT PROCESS
-- ==========================================

-- Wait in line at a register, moving forward when position changes
-- Returns true when the NPC reaches position 1 (front of the line)
local function waitInLine(npc: Model, registerModel: Model, startPosition: number): boolean
	local checkoutService = cachedModules.Cache.CheckoutService
	if not checkoutService then return false end

	local lastPosition = startPosition
	local humanoid = npc:FindFirstChildOfClass("Humanoid")
	if not humanoid then return false end

	-- Move to the initial queue point
	local queuePoint = checkoutService.getQueuePoint(registerModel, startPosition)
	if queuePoint then
		moveToPosition(npc, queuePoint.Position)
	end

	-- Poll for position changes until we reach the front
	while true do
		if not npc.Parent or humanoid.Health <= 0 then return false end

		local currentPos = checkoutService.getPositionInQueue(registerModel, npc)

		if currentPos == nil then
			-- No longer in queue
			return false
		elseif currentPos ~= lastPosition then
			-- Position changed, move to the new queue point
			lastPosition = currentPos
			local newQueuePoint = checkoutService.getQueuePoint(registerModel, currentPos)
			if newQueuePoint then
				moveToPosition(npc, newQueuePoint.Position)
			end
			-- Reached the front of the line
			if currentPos == 1 then
				return true
			end
		end

		task.wait(0.5)
	end
end

-- Perform the checkout at a register
-- Payout is calculated HERE (delayed payout) - not during browsing
-- Formula: PricePerItem x ItemsBought x SpendMultiplier x MutationMultiplier
local function performCheckout(npc: Model, registerModel: Model, rackModel: Model, itemsBought: number, plot: Model): boolean
	local checkoutService = cachedModules.Cache.CheckoutService
	if not checkoutService then return false end

	local humanoid = npc:FindFirstChildOfClass("Humanoid")
	if not humanoid then return false end

	-- Wait for the register to be staffed (IsStaffed == true)
	while not checkoutService.isStaffed(registerModel) do
		if not npc.Parent or humanoid.Health <= 0 then return false end
		task.wait(0.5)
	end

	-- Checkout process: wait for the configured checkout time
	local checkoutTime = checkoutService.getCheckoutTime()
	task.wait(checkoutTime)

	if not npc.Parent or humanoid.Health <= 0 then return false end

	-- Calculate payout NOW at checkout (delayed payout)
	if itemsBought > 0 and rackModel then
		local boutiqueShopService = cachedModules.Cache.BoutiqueShopService
		local customerAIService = cachedModules.Cache.CustomerAIService
		if boutiqueShopService then
			local isVIP = npc:GetAttribute("IsVIP") == true
			local spendMultiplier = customerAIService and customerAIService.getCustomerTypeConfig(isVIP).SpendMultiplier or 1.0
			local payout = boutiqueShopService.calculatePayout(rackModel, itemsBought, spendMultiplier)
			boutiqueShopService.awardPayout(plot, payout)
			print("[CustomerService] " .. (isVIP and "VIP" or "Regular") .. " customer checkout: " .. itemsBought .. " items, payout = " .. payout)
		end
	end

	-- Remove from queue (this shifts everyone forward automatically)
	checkoutService.removeCustomer(registerModel, npc)

	return true
end

-- ==========================================
-- MAIN CUSTOMER LIFECYCLE
-- ==========================================

-- Run the full lifecycle of a single customer NPC
-- States: Spawn -> Browse Rack -> Walk to Register -> Wait in Line -> Checkout -> Leave
function CustomerService.runCustomer(npc: Model, plot: Model, spawnZone: BasePart)
	if not npc or not plot or not spawnZone then return end

	local humanoid = npc:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		warn("[CustomerService] NPC has no Humanoid, aborting lifecycle")
		if npc.Parent then npc.Parent = nil end
		return
	end

	local state = CustomerService.States.Spawning
	local rackModel = nil
	local itemsBought = 0

	local boutiqueShopService = cachedModules.Cache.BoutiqueShopService
	local checkoutService = cachedModules.Cache.CheckoutService

	if not boutiqueShopService or not checkoutService then
		warn("[CustomerService] Required services not available")
		if npc.Parent then npc.Parent = nil end
		return
	end

	-- ==========================================
	-- STATE: BROWSING - Walk to an available fabric rack and browse
	-- ==========================================
	state = CustomerService.States.Browsing

	local racks = boutiqueShopService.getRacksOnPlot(plot)

	if #racks > 0 then
		-- Find available racks (not being browsed, has stock)
		local availableRacks = findAvailableRacks(racks)

		-- If no available racks, retry a few times with short waits
		local attempts = 0
		while #availableRacks == 0 and attempts < 3 do
			task.wait(2)
			if not npc.Parent or humanoid.Health <= 0 then
				if npc.Parent then npc.Parent = nil end
				return
			end
			availableRacks = findAvailableRacks(racks)
			attempts += 1
		end

		if #availableRacks > 0 then
			-- Pick a random available rack
			local rack = availableRacks[math.random(1, #availableRacks)]
			rackModel, itemsBought = browseRack(npc, rack)
		else
			-- All racks busy or empty - pick any rack as fallback
			local rack = racks[math.random(1, #racks)]
			rackModel, itemsBought = browseRack(npc, rack)
		end
	else
		-- No racks on the plot - wait briefly then leave
		task.wait(2)
	end

	-- Abort if NPC was destroyed or died while browsing
	if not npc.Parent or humanoid.Health <= 0 then
		if rackModel then
			rackModel:SetAttribute("BeingBrowsed", false)
		end
		if npc.Parent then npc.Parent = nil end
		return
	end

	-- Only proceed to checkout if they actually bought something
	if itemsBought == 0 or not rackModel then
		-- Customer didn't buy anything, head to exit
		state = CustomerService.States.Leaving
		if npc.Parent and humanoid.Health > 0 then
			moveToPosition(npc, spawnZone.Position)
		end
		if npc.Parent then npc.Parent = nil end
		return
	end

	-- ==========================================
	-- STATE: WALKING TO REGISTER
	-- ==========================================
	state = CustomerService.States.WalkingToRegister

	local registers = boutiqueShopService.getRegistersOnPlot(plot)

	if #registers > 0 then
		-- Pick the first register (could be extended to pick shortest line)
		local register = registers[1]

		-- Register with CheckoutService (First Come, First Served)
		local position = checkoutService.addCustomer(register, npc)

		if position == 1 then
			state = CustomerService.States.CheckingOut
		else
			state = CustomerService.States.WaitingInLine
		end

		-- ==========================================
		-- STATE: WAITING IN LINE - Move forward when people ahead finish
		-- ==========================================
		if position > 1 then
			local success = waitInLine(npc, register, position)
			if not success then
				-- NPC was destroyed or removed from queue while waiting
				checkoutService.removeCustomer(register, npc)
				if npc.Parent then npc.Parent = nil end
				return
			end
			state = CustomerService.States.CheckingOut
		end

		-- ==========================================
		-- STATE: CHECKING OUT - Payout calculated HERE (delayed payout)
		-- ==========================================
		local checkoutSuccess = performCheckout(npc, register, rackModel, itemsBought, plot)
		if not checkoutSuccess then
			checkoutService.removeCustomer(register, npc)
			if npc.Parent then npc.Parent = nil end
			return
		end
	else
		-- No registers on the plot - customer leaves without checking out
		print("[CustomerService] No registers on plot " .. plot.Name .. ", customer leaving")
	end

	-- ==========================================
	-- STATE: LEAVING - Walk back to NPCSpawnZone (exit point)
	-- ==========================================
	state = CustomerService.States.Leaving

	if npc.Parent and humanoid.Health > 0 then
		moveToPosition(npc, spawnZone.Position)
	end

	-- Clean up the NPC
	if npc.Parent then
		npc.Parent = nil
	end
end

-- ==========================================
-- INITIALIZATION
-- ==========================================

function CustomerService.init()
	print("[CustomerService] Initialized! Delayed payout, single-browser rack cap, queue fix applied")
end

return CustomerService
