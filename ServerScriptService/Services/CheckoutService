local CollectionService = game:GetService("CollectionService")
local Players = game:GetService("Players")
local cachedModules = require(script.Parent.Parent.Server.CachedModules)

-- Track which players are currently standing on each register's EmployeeStandPart
-- staffingPlayers[registerModel] = { [player] = true }
local staffingPlayers = {}

local CheckoutService = {}

-- ==========================================
-- CONFIGURATION
-- ==========================================
CheckoutService.CheckoutTime = 3
CheckoutService.EmployeeCheckoutTime = 3

-- Queue table: [registerModel] = {npc1, npc2, npc3, ...}
local RegisterQueues = {}

-- ==========================================
-- QUEUE MANAGEMENT
-- ==========================================

function CheckoutService.getQueue(registerModel: Model)
	if not RegisterQueues[registerModel] then
		RegisterQueues[registerModel] = {}
	end
	return RegisterQueues[registerModel]
end

function CheckoutService.getLineCount(registerModel: Model): number
	local queue = CheckoutService.getQueue(registerModel)
	return #queue
end

function CheckoutService.addCustomer(registerModel: Model, npcModel: Model): number
	local queue = CheckoutService.getQueue(registerModel)
	table.insert(queue, npcModel)
	registerModel:SetAttribute("LineOccupants", #queue)
	return #queue
end

function CheckoutService.removeCustomer(registerModel: Model, npcModel: Model): number
	local queue = CheckoutService.getQueue(registerModel)
	for i, npc in ipairs(queue) do
		if npc == npcModel then
			table.remove(queue, i)
			break
		end
	end
	registerModel:SetAttribute("LineOccupants", #queue)
	return #queue
end

function CheckoutService.getPositionInQueue(registerModel: Model, npcModel: Model): number?
	local queue = CheckoutService.getQueue(registerModel)
	for i, npc in ipairs(queue) do
		if npc == npcModel then
			return i
		end
	end
	return nil
end

-- ==========================================
-- QUEUE POINTS
-- ==========================================

function CheckoutService.getQueuePoint(registerModel: Model, position: number): BasePart?
	local queuePointName = "QueuePoint_" .. tostring(position)
	return registerModel:FindFirstChild(queuePointName)
end

function CheckoutService.getAllQueuePoints(registerModel: Model): {BasePart}
	local points = {}
	for _, child in ipairs(registerModel:GetChildren()) do
		local name = child.Name
		if name:match("^QueuePoint_%d+$") then
			local pos = tonumber(name:match("%d+"))
			if pos then
				table.insert(points, { part = child, position = pos })
			end
		end
	end
	table.sort(points, function(a, b) return a.position < b.position end)

	local result = {}
	for _, entry in ipairs(points) do
		table.insert(result, entry.part)
	end
	return result
end

-- ==========================================
-- STAFFING
-- ==========================================

function CheckoutService.isStaffed(registerModel: Model): boolean
	return registerModel:GetAttribute("IsStaffed") == true
end

function CheckoutService.setStaffed(registerModel: Model, isStaffed: boolean)
	registerModel:SetAttribute("IsStaffed", isStaffed)
end

-- ==========================================
-- REGISTER PARTS
-- ==========================================

-- Get the EmployeeStandPart for a register
function CheckoutService.getEmployeeStandPart(registerModel: Model): BasePart?
	return registerModel:FindFirstChild("EmployeeStandPart")
end

-- ==========================================
-- TIMING CONFIGURATION
-- ==========================================

function CheckoutService.getCheckoutTime(): number
	return CheckoutService.CheckoutTime
end

function CheckoutService.getEmployeeCheckoutTime(): number
	return CheckoutService.EmployeeCheckoutTime
end

-- ==========================================
-- INITIALIZATION
-- ==========================================

local function isPlayerCharacter(part: BasePart): Player?
	local character = part.Parent
	if not character then return nil end
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return nil end
	return Players:GetPlayerFromCharacter(character)
end

-- Recompute IsStaffed based on players table
local function recomputeStaffed(registerModel: Model)
	local players = staffingPlayers[registerModel]
	if players then
		for player in pairs(players) do
			if not player.Parent or not player.Character then
				players[player] = nil
			end
		end

		if next(players) then
			CheckoutService.setStaffed(registerModel, true)
			for player in pairs(players) do
				registerModel:SetAttribute("StaffedBy", player.UserId)
				break
			end
			return
		end
	end

	-- If no players are tracking, check if an NPC employee is still occupying the attribute before shutting it down
	if registerModel:GetAttribute("StaffedBy") == "NPC_Employee" then
		CheckoutService.setStaffed(registerModel, true)
	else
		CheckoutService.setStaffed(registerModel, false)
		registerModel:SetAttribute("StaffedBy", 0)
	end
end

-- Set up touch-based staffing for a register's EmployeeStandPart
local function setupStaffingTouch(registerModel: Model)
	local standPart = CheckoutService.getEmployeeStandPart(registerModel)
	if not standPart then
		warn("[CheckoutService] No EmployeeStandPart found on register: " .. registerModel.Name)
		return
	end

	staffingPlayers[registerModel] = staffingPlayers[registerModel] or {}

	-- When someone steps onto the stand part
	standPart.Touched:Connect(function(hit)
		local player = isPlayerCharacter(hit)
		local character = hit.Parent

		local isValidStaff = false
		if player then
			isValidStaff = true
		elseif character and character:GetAttribute("IsNPCEmployee") == true then
			isValidStaff = true
		end

		if not isValidStaff then return end

		-- Plot Ownership Security Block: Stop players staffing other people's checkout lines!
		local registerPlot = registerModel:FindFirstAncestorOfClass("Model")
		while registerPlot and registerPlot.Parent ~= workspace.Plots do
			registerPlot = registerPlot.Parent
		end
		if player and registerPlot then
			local ownerId = registerPlot:GetAttribute("USERID")
			if ownerId ~= player.UserId then
				return -- Secure escape!
			end
		end

		if player then
			local players = staffingPlayers[registerModel]
			if not players[player] then
				players[player] = true
				recomputeStaffed(registerModel)
			end
		elseif character then
			CheckoutService.setStaffed(registerModel, true)
			registerModel:SetAttribute("StaffedBy", "NPC_Employee")
		end
	end)

	-- When someone steps off the stand part
	standPart.TouchEnded:Connect(function(hit)
		local player = isPlayerCharacter(hit)
		local character = hit.Parent

		-- MAX Studs away a character can be before they are counted as "fully left"
		local strictExitRadius = 4 

		if player then
			local players = staffingPlayers[registerModel]
			if players[player] then
				task.wait(0.15) -- Quick debounce

				local char = player.Character
				local hrp = char and char:FindFirstChild("HumanoidRootPart")
				if hrp and standPart then
					-- Calculate flat X/Z plane distance so jump height doesn't break it
					local distance = (Vector3.new(hrp.Position.X, 0, hrp.Position.Z) - Vector3.new(standPart.Position.X, 0, standPart.Position.Z)).Magnitude
					if distance < strictExitRadius then
						return -- Still lingering inside zone, don't unstaff
					end
				end

				players[player] = nil
				recomputeStaffed(registerModel)
			end
		elseif character and character:GetAttribute("IsNPCEmployee") == true then
			task.wait(0.15)

			local hrp = character:FindFirstChild("HumanoidRootPart")
			if hrp and standPart then
				local distance = (Vector3.new(hrp.Position.X, 0, hrp.Position.Z) - Vector3.new(standPart.Position.X, 0, standPart.Position.Z)).Magnitude
				if distance < strictExitRadius then
					return -- NPC is still standing there
				end
			end

			-- Only wipe the NPC state if a player isn't currently using the register
			if registerModel:GetAttribute("StaffedBy") == "NPC_Employee" then
				registerModel:SetAttribute("StaffedBy", 0)
			end
			recomputeStaffed(registerModel)
		end
	end)
end

local function setupRegister(registerModel: Model)
	registerModel:SetAttribute("IsRegister", true)
	registerModel:SetAttribute("LineOccupants", 0)
	registerModel:SetAttribute("IsStaffed", false)
	registerModel:SetAttribute("StaffedBy", 0)
	RegisterQueues[registerModel] = {}
	setupStaffingTouch(registerModel)
	print("[CheckoutService] Register detected and initialized: " .. registerModel.Name)
end

local function onPlayerRemoving(player: Player)
	for _, registerModel in ipairs(CollectionService:GetTagged("CashRegister")) do
		local players = staffingPlayers[registerModel]
		if players and players[player] then
			players[player] = nil
			recomputeStaffed(registerModel)
			print("[CheckoutService] Auto-unstaffed register (player left): " .. registerModel.Name)
		end
	end
end

function CheckoutService.init()
	CollectionService:GetInstanceAddedSignal("CashRegister"):Connect(setupRegister)

	for _, registerModel in ipairs(CollectionService:GetTagged("CashRegister")) do
		setupRegister(registerModel)
	end

	Players.PlayerRemoving:Connect(onPlayerRemoving)

	print("[CheckoutService] Initialized! CheckoutTime = " .. CheckoutService.CheckoutTime .. "s, EmployeeCheckoutTime = " .. CheckoutService.EmployeeCheckoutTime .. "s")
end

return CheckoutService
