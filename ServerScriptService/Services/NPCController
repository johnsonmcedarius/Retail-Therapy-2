local ServerStorage = game:GetService("ServerStorage")
local Players = game:GetService("Players")
local CollectionService = game:GetService("CollectionService")
local PhysicsService = game:GetService("PhysicsService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local cachedModules = require(script.Parent.Parent.Server.CachedModules)
local RemoteEvents = ReplicatedStorage:WaitForChild("RemoteEvents")
local customerNotification = RemoteEvents:WaitForChild("CustomerNotification")

local NPCController = {}

-- ==========================================
-- CONFIGURATION
-- ==========================================
NPCController.MaxNPCsPerPlot = 5
NPCController.SpawnInterval = { min = 5, max = 10 }
NPCController.NPCNames = { "NPC", "NPC2", "NPC3", "NPC4", "NPC5" }

-- ==========================================
-- STATE
-- ==========================================
local activeNPCs = {}
local customerFolder = nil

-- ==========================================
-- COLLISION GROUPS
-- ==========================================

local function setCollisionGroupRecursive(model: Model, groupName: string)
	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant:IsA("BasePart") then
			local success = pcall(function()
				descendant.CollisionGroup = groupName
			end)
		end
	end
end

-- Assign NPC parts
local function assignNPCCollisionGroup(model: Model)
	setCollisionGroupRecursive(model, "NPCs")

	-- [[ HOTFIX: Kill root collision so they don't catch on player capsules ]]
	local hrp = model:FindFirstChild("HumanoidRootPart")
	if hrp then
		hrp.CanCollide = false
	end

	model.DescendantAdded:Connect(function(descendant)
		if descendant:IsA("BasePart") then
			descendant.CollisionGroup = "NPCs"
			if descendant.Name == "Handle" or descendant.Name == "HumanoidRootPart" then
				descendant.CanCollide = false
			end
		end
	end)
end

-- Assign Player parts
local function assignPlayerCollisionGroup(character: Model)
	setCollisionGroupRecursive(character, "Players")

	-- [[ HOTFIX: Force root collision checks ]]
	local hrp = character:FindFirstChild("HumanoidRootPart")
	if hrp then
		hrp.CanCollide = false -- Server-side fallback
	end

	character.DescendantAdded:Connect(function(descendant)
		if descendant:IsA("BasePart") then
			descendant.CollisionGroup = "Players"
		end
	end)
end

-- ==========================================
-- NPC MODEL SELECTION
-- ==========================================

local function getRandomModelFromFolder(folder: Instance): Model?
	if not folder then return nil end
	local name = NPCController.NPCNames[math.random(1, #NPCController.NPCNames)]
	local template = folder:FindFirstChild(name)
	if not template then return nil end
	return template:Clone()
end

local function getRandomRegularNPCModel(): Model?
	return getRandomModelFromFolder(ServerStorage:FindFirstChild("NPC"))
end

local function getRandomVIPNPCModel(): Model?
	return getRandomModelFromFolder(ServerStorage:FindFirstChild("VIPNPC"))
end

-- ==========================================
-- APPEARANCE LOADER
-- ==========================================

local function applyFriendAppearance(npc: Model, plotOwnerUserId: number): boolean
	local success, friendPages = pcall(function()
		return Players:GetFriendsAsync(plotOwnerUserId)
	end)

	if not success or not friendPages then return false end

	local friendsPage = friendPages:GetCurrentPage()
	if not friendsPage or #friendsPage == 0 then return false end

	local friend = friendsPage[math.random(1, #friendsPage)]

	local descSuccess, humanoidDescription = pcall(function()
		return Players:GetHumanoidDescriptionFromUserIdAsync(friend.Id)
	end)

	if not descSuccess or not humanoidDescription then return false end

	local humanoid = npc:FindFirstChildOfClass("Humanoid")
	if not humanoid then return false end

	for _, child in ipairs(npc:GetChildren()) do
		if child:IsA("Accessory") or child:IsA("Clothing") or child:IsA("ShirtGraphic") or child:IsA("BodyColors") then
			child:Destroy()
		end
	end

	local applySuccess = pcall(function()
		humanoid:ApplyDescriptionAsync(humanoidDescription)
	end)

	return applySuccess
end

local function getActiveNPCCount(plot: Model): number
	local npcs = activeNPCs[plot]
	if not npcs then return 0 end

	for i = #npcs, 1, -1 do
		if not npcs[i].Parent then
			table.remove(npcs, i)
		end
	end

	return #npcs
end

-- ==========================================
-- SPAWNING
-- ==========================================

local function spawnCustomerNPC(plot: Model, spawnZone: BasePart)
	local boutiqueShopService = cachedModules.Cache.BoutiqueShopService
	local customerAIService = cachedModules.Cache.CustomerAIService

	local isVIP = customerAIService and customerAIService.rollCustomerType() or false
	local npc = isVIP and getRandomVIPNPCModel() or getRandomRegularNPCModel()
	if not npc then
		npc = isVIP and getRandomRegularNPCModel() or getRandomVIPNPCModel()
	end
	if not npc then return end

	npc:SetAttribute("IsVIP", isVIP)

	-- Fire VIP notification to plot owner when a VIP customer enters
	if isVIP and boutiqueShopService then
		local isActive, plotOwner = boutiqueShopService.isPlotActive(plot)
		if isActive and plotOwner then
			customerNotification:FireClient(plotOwner, "VIP", "A VIP customer has entered your store!")
		end
	end

	local hrp = npc:FindFirstChild("HumanoidRootPart")
	if hrp then
		local spawnPosition = spawnZone.Position + Vector3.new(math.random(-3, 3), 0, math.random(-3, 3))
		hrp.CFrame = CFrame.new(spawnPosition)
	end

	npc.Parent = customerFolder

	if hrp then
		pcall(function()
			hrp:SetNetworkOwner(nil)
		end)
	end

	assignNPCCollisionGroup(npc)

	if boutiqueShopService then
		local isActive, player = boutiqueShopService.isPlotActive(plot)
		if isActive and player then
			applyFriendAppearance(npc, player.UserId)
		end
	end

	if not activeNPCs[plot] then activeNPCs[plot] = {} end
	table.insert(activeNPCs[plot], npc)

	local customerService = cachedModules.Cache.CustomerService
	if customerService then
		task.spawn(function()
			customerService.runCustomer(npc, plot, spawnZone)
			if activeNPCs[plot] then
				for i, n in ipairs(activeNPCs[plot]) do
					if n == npc then
						table.remove(activeNPCs[plot], i)
						break
					end
				end
			end
		end)
	else
		npc.Parent = nil
	end
end

local function runSpawnLoop()
	while true do
		local boutiqueShopService = cachedModules.Cache.BoutiqueShopService
		local checkoutService = cachedModules.Cache.CheckoutService

		if boutiqueShopService and checkoutService then
			for _, plot in ipairs(boutiqueShopService.getPlots()) do
				if not plot:IsA("Model") then continue end

				local isActive = boutiqueShopService.isPlotActive(plot)
				if isActive then
					local spawnZone = boutiqueShopService.getSpawnZone(plot)
					if spawnZone then
						local registers = boutiqueShopService.getRegistersOnPlot(plot)
						local linesAreFull = false

						if #registers > 0 then
							linesAreFull = true
							for _, register in ipairs(registers) do
								local currentLineCount = checkoutService.getLineCount(register)
								local maxLineCapacity = #checkoutService.getAllQueuePoints(register)

								if currentLineCount < maxLineCapacity then
									linesAreFull = false
									break
								end
							end
						end

						local currentCount = getActiveNPCCount(plot)
						if currentCount < NPCController.MaxNPCsPerPlot and not linesAreFull then
							spawnCustomerNPC(plot, spawnZone)
						end
					end
				end
			end
		end
		task.wait(math.random(NPCController.SpawnInterval.min, NPCController.SpawnInterval.max))
	end
end

local function cleanupPlotNPCs(plot: Model)
	local npcs = activeNPCs[plot]
	if not npcs then return end
	for _, npc in ipairs(npcs) do
		if npc.Parent then npc.Parent = nil end
	end
	activeNPCs[plot] = nil
end

-- ==========================================
-- INITIALIZATION
-- ==========================================

function NPCController.init()
	-- [[ FIX: Removed the script-side group registration so it stops overriding your Studio window settings ]]

	local function onCharacterAdded(character: Model)
		-- Wait a brief heartbeat for components to build safely
		task.defer(function()
			assignPlayerCollisionGroup(character)
		end)
	end

	Players.PlayerAdded:Connect(function(player)
		player.CharacterAdded:Connect(onCharacterAdded) 
	end)

	for _, player in ipairs(Players:GetPlayers()) do 
		if player.Character then 
			onCharacterAdded(player.Character) 
		end 
		player.CharacterAdded:Connect(onCharacterAdded) 
	end

	customerFolder = workspace:FindFirstChild("CustomerNPCs") 
	if not customerFolder then 
		customerFolder = Instance.new("Folder") 
		customerFolder.Name = "CustomerNPCs" 
		customerFolder.Parent = workspace 
	end

	task.spawn(runSpawnLoop) 

	Players.PlayerRemoving:Connect(function(player)
		for _, plot in ipairs(workspace.Plots:GetChildren()) do 
			if plot:IsA("Model") and plot:GetAttribute("USERID") == player.UserId then 
				cleanupPlotNPCs(plot)
				break
			end
		end
	end)

	print("[NPCController] Handled perfectly via Studio parameters.") 
end

return NPCController
