-- ============================================================
-- HELPERS
-- ============================================================

-- Find the local player's plot
local function getPlot()
	for _, plot in workspace.Plots:GetChildren() do
		if plot:GetAttribute("USERID") == player.UserId then
			return plot
		end
	end
	return nil
end

-- Find an asset by name in BuildMode.Assets folders
local function findAssetByName(name)
	for _, folder in buildAssets:GetChildren() do
		if folder:IsA("Folder") then
			local asset = folder:FindFirstChild(name)
			if asset then return asset end
		end
	end
	return nil
end

-- Get the adornment part for a build object (PrimaryPart for Model, itself for Part)
local function getAdornee(object)
	if object:IsA("BasePart") then return object end
	if object:IsA("Model") then
		if object.PrimaryPart then return object.PrimaryPart end
		for _, child in object:GetChildren() do
			if child:IsA("BasePart") then return child end
		end
	end
	return nil
end

-- Collect all BaseParts in an object with their current properties
local function collectPartStates(object)
	local states = {}
	if object:IsA("BasePart") then
		table.insert(states, {part = object, transparency = object.Transparency, canQuery = object.CanQuery})
	elseif object:IsA("Model") then
		for _, descendant in object:GetDescendants() do
			if descendant:IsA("BasePart") then
				table.insert(states, {part = descendant, transparency = descendant.Transparency, canQuery = descendant.CanQuery})
			end
		end
	end
	return states
end

-- Hide/show proximity prompts and out-of-stock visuals on a rack
local function setRackVisualsHidden(rack, hidden)
	local interactionPart = rack:FindFirstChild("InteractionPart", true)
	if not interactionPart then return end

	-- Toggle proximity prompts
	for _, descendant in interactionPart:GetDescendants() do
		if descendant:IsA("ProximityPrompt") then
			descendant.Enabled = not hidden
		end
	end

	-- Toggle out-of-stock part and GUI
	local outofstockPart = interactionPart:FindFirstChild("OutofstockPart")
	if outofstockPart and outofstockPart:IsA("BasePart") then
		outofstockPart.Transparency = hidden and 1 or 0
		local outofstockGUI = outofstockPart:FindFirstChild("OutofstockGUI")
		if outofstockGUI and outofstockGUI:IsA("BillboardGui") then
			outofstockGUI.Enabled = not hidden
		end
	end
end

-- Restore part states after move
local function restorePartStates(states)
	for _, state in states do
		state.part.Transparency = state.transparency
		state.part.CanQuery = state.canQuery
	end
end

-- ============================================================
-- BBGUI MANAGEMENT
-- ============================================================

local startMove  -- forward declaration so showBBGUI can reference it
local cancelMove = nil -- forward declaration so we can cancel move from outside

local function removeBBGUI()
	if activeBBGUI then
		activeBBGUI:Destroy()
		activeBBGUI = nil
	end
	selectedObject = nil
end

local function showBBGUI(object)
	removeBBGUI()
	selectedObject = object

	local clone = bbguiTemplate:Clone()
	clone.Enabled = true
	clone.Active = true -- Blocks click-throughs to the world raycast entirely
	local adornee = getAdornee(object)
	clone.Adornee = adornee
	clone.Parent = object

	local moveBB = clone:FindFirstChild("MoveBB")
	local sellBB = clone:FindFirstChild("SellBB")
	local storeBB = clone:FindFirstChild("StoreBB")
	local cancelBB = clone:FindFirstChild("CancelBB")

	-- Explicitly set UI buttons to active so they sync input correctly
	local function prepButton(btn)
		if btn then btn.Active = true end
	end
	prepButton(moveBB)
	prepButton(sellBB)
	prepButton(storeBB)
	prepButton(cancelBB)

	if moveBB then
		moveBB.Activated:Connect(function()
			local id = object:GetAttribute("BuildId")
			removeBBGUI()
			if id then startMove(object, id) end
		end)
	end

	if sellBB then
		sellBB.Activated:Connect(function()
			local id = object:GetAttribute("BuildId")
			if id then
				deleteEvent:FireServer({ObjectId = id, Reason = "delete"})
			end
			removeBBGUI()
		end)
	end

	if storeBB then
		storeBB.Activated:Connect(function()
			local id = object:GetAttribute("BuildId")
			if id then
				storeEvent:FireServer({ObjectId = id})
			end
			removeBBGUI()
		end)
	end

	if cancelBB then
		cancelBB.Activated:Connect(function()
			removeBBGUI()
		end)
	end

	activeBBGUI = clone
end

-- ============================================================
-- MOVE MODE (Cross-Platform)
-- ============================================================

function startMove(object, buildId)
	if isMoving then return end
	isMoving = true

	local asset = findAssetByName(object.Name)
	if not asset then
		isMoving = false
		return
	end

	local partStates = collectPartStates(object)
	for _, state in partStates do
		state.part.Transparency = 0.7
		state.part.CanQuery = false
	end

	setRackVisualsHidden(object, true)
	player:SetAttribute("IsMovingBuild", true)

	moveHighlight = Instance.new("Highlight")
	moveHighlight.Parent = workspace

	PlacingService.SetPreview(asset)
	moveTrove = Trove.new()

	moveTrove:Connect(PlacingService.Rendered, function(preview, cf, canPlace)
		moveHighlight.Adornee = preview
		local color = canPlace and Settings.CanPlaceColor or Settings.CannotPlaceColor
		moveHighlight.OutlineColor = color
		moveHighlight.FillColor = color
	end)

	local function cleanupMove()
		cancelMove = nil
		-- Unbind Context Actions safely
		ContextActionService:UnbindAction("PlaceObjectAction")
		ContextActionService:UnbindAction("RotateObjectAction")
		ContextActionService:UnbindAction("CancelPlacementAction")

		if moveTrove then
			moveTrove:Clean()
			moveTrove = nil
		end

		PlacingService.Cancel()
		if moveHighlight then
			moveHighlight:Destroy()
			moveHighlight = nil
		end
		restorePartStates(partStates)
		setRackVisualsHidden(object, false)
		player:SetAttribute("IsMovingBuild", false)
		isMoving = false
	end

	cancelMove = cleanupMove

	-- Unified Cross-Platform Action Handler
	local function handlePlacement(actionName, inputState, inputObj)
		if inputState ~= Enum.UserInputState.Begin then return end

		if actionName == "PlaceObjectAction" then
			local preview = PlacingService.GetPreview()
			if not preview then return end

			local cf = PlacingService._CF
			local canPlace = PlacingService.CanPlace
			if not cf or not canPlace then return end

			moveEvent:FireServer({ObjectId = buildId, CF = cf})
			cleanupMove()

		elseif actionName == "RotateObjectAction" then
			PlacingService.Rotate(Vector3.yAxis)

		elseif actionName == "CancelPlacementAction" then
			cleanupMove()
		end
	end

	-- Bind actions across Keyboard, Touch Buttons, and Gamepads
	ContextActionService:BindAction("PlaceObjectAction", handlePlacement, true, Enum.UserInputType.MouseButton1, Enum.KeyCode.ButtonA)
	ContextActionService:BindAction("RotateObjectAction", handlePlacement, true, Settings.RotateY, Enum.KeyCode.ButtonY)
	ContextActionService:BindAction("CancelPlacementAction", handlePlacement, true, Settings.Cancel, Enum.KeyCode.ButtonB)

	-- Customize touch button text for mobile overlays
	ContextActionService:SetTitle("PlaceObjectAction", "Place")
	ContextActionService:SetTitle("RotateObjectAction", "Rotate")
	ContextActionService:SetTitle("CancelPlacementAction", "Cancel")
end

-- ============================================================
-- CLICK / SELECTION DETECTION
-- ============================================================

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if not buildGui.Enabled then return end

	-- Handle selection inputs: Click, Touch Tap, or Console Selection Button
	local isValidInput = (input.UserInputType == Enum.UserInputType.MouseButton1) or 
		(input.UserInputType == Enum.UserInputType.Touch) or
		(input.KeyCode == Enum.KeyCode.ButtonA)

	if not isValidInput then return end
	if isMoving or PlacingService.GetPreview() then return end
	if player:GetAttribute("DeleteMode") == true then return end

	-- Figure out target screen position based on device type
	local screenPos
	if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
		screenPos = UserInputService:GetMouseLocation()
	else
		-- If console/gamepad, cast directly from the center of the viewport
		screenPos = camera.ViewportSize / 2
	end

	local ray = camera:ViewportPointToRay(screenPos.X, screenPos.Y)
	local plot = getPlot()
	if not plot then return end

	local buildObjects = plot:FindFirstChild("BuildObjects")
	if not buildObjects then return end

	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Include
	raycastParams.FilterDescendantsInstances = { buildObjects }

	local result = workspace:Raycast(ray.Origin, ray.Direction * 2048, raycastParams)
	if not result then
		return
	end

	local targetObject = result.Instance
	while targetObject and targetObject.Parent ~= buildObjects do
		targetObject = targetObject.Parent
	end

	if not targetObject or not targetObject:GetAttribute("BuildId") then return end
	if selectedObject == targetObject and activeBBGUI then return end

	showBBGUI(targetObject)
end)

-- Universal cancel key handler for active UI menus
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if isMoving then return end
	if not buildGui.Enabled then return end
	if input.KeyCode == Settings.Cancel or input.KeyCode == Enum.KeyCode.ButtonB then
		removeBBGUI()
	end
end)

buildGui:GetPropertyChangedSignal("Enabled"):Connect(function()
	if not buildGui.Enabled then
		if cancelMove then cancelMove() end
		removeBBGUI()
	end
end)

-- Listen for cancel move requests from other scripts (e.g., BuildActions CancelButton)
player:GetAttributeChangedSignal("CancelMoveRequest"):Connect(function()
	if player:GetAttribute("CancelMoveRequest") and isMoving then
		if cancelMove then cancelMove() end
	end
end)

-- ============================================================
-- INVENTORY SYSTEM
-- ============================================================

local inventoryFrame = buildGui:WaitForChild("Inventory")
local inventoryTemplate = inventoryFrame:WaitForChild("InventoryTemplate")
inventoryTemplate.Parent = nil 

local function setupViewport(viewportFrame, object)
	local clone = object:Clone()
	clone:PivotTo(CFrame.new(Vector3.zero))
	for _, descendant in clone:GetDescendants() do
		if descendant:IsA("BasePart") then descendant.Anchored = true end
	end
	clone.Parent = viewportFrame

	local cam = Instance.new("Camera")
	cam.Parent = viewportFrame
	viewportFrame.CurrentCamera = cam

	local cf, size = clone:GetBoundingBox()
	local maxDim = math.max(size.X, size.Y, size.Z)
	local distance = maxDim * 1.5
	cam.CFrame = CFrame.new(cf.Position + Vector3.new(distance, distance * 0.6, distance), cf.Position)
end

local function populateInventory(inventoryData)
	for _, child in inventoryFrame:GetChildren() do
		if child.Name ~= "InventoryTemplate" and child:IsA("TextButton") then
			child:Destroy()
		end
	end

	for itemName, count in pairs(inventoryData) do
		if count > 0 then
			local asset = findAssetByName(itemName)
			if asset then
				local button = inventoryTemplate:Clone()
				button.Name = itemName
				button.Parent = inventoryFrame

				local nameLabel = button:FindFirstChild("BuildNameLabel")
				if nameLabel then nameLabel.Text = itemName .. " (x" .. count .. ")" end

				local coinLabel = button:FindFirstChild("CoinPriceLabel")
				if coinLabel then coinLabel.Visible = false end
				local diamondLabel = button:FindFirstChild("DiamondPriceLabel")
				if diamondLabel then diamondLabel.Visible = false end

				local viewport = button:FindFirstChild("ViewportFrame")
				if viewport then setupViewport(viewport, asset) end

				button.MouseButton1Click:Connect(function()
					removeBBGUI()
					local previewTrove = Trove.new()
					PlacingService.SetPreview(asset)

					local highlight = Instance.new("Highlight")
					highlight.Parent = workspace

					previewTrove:Connect(PlacingService.Rendered, function(preview, cf, canPlace)
						highlight.Adornee = preview
						local color = canPlace and Settings.CanPlaceColor or Settings.CannotPlaceColor
						highlight.OutlineColor = color
						highlight.FillColor = color
					end)

					local function cleanupInventoryPlacement()
						ContextActionService:UnbindAction("InventoryPlaceAction")
						ContextActionService:UnbindAction("InventoryRotateAction")
						ContextActionService:UnbindAction("InventoryCancelAction")
						if previewTrove then previewTrove:Clean() end
						PlacingService.Cancel()
						if highlight then highlight:Destroy() end
					end

					local function handleInventoryPlacement(actionName, inputState, inputObj)
						if inputState ~= Enum.UserInputState.Begin then return end

						if actionName == "InventoryPlaceAction" then
							local preview = PlacingService.GetPreview()
							if not preview then return end

							local cf = PlacingService._CF
							local canPlace = PlacingService.CanPlace
							if not cf or not canPlace then return end

							placeEvent:FireServer({
								ObjectName = itemName,
								CF = cf,
								FromInventory = true,
							})

							-- If holding Control (PC), keep placement mode open for multi-place
							if not UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
								cleanupInventoryPlacement()
							end

						elseif actionName == "InventoryRotateAction" then
							PlacingService.Rotate(Vector3.yAxis)

						elseif actionName == "InventoryCancelAction" then
							cleanupInventoryPlacement()
						end
					end

					ContextActionService:BindAction("InventoryPlaceAction", handleInventoryPlacement, true, Enum.UserInputType.MouseButton1, Enum.KeyCode.ButtonA)
					ContextActionService:BindAction("InventoryRotateAction", handleInventoryPlacement, true, Settings.RotateY, Enum.KeyCode.ButtonY)
					ContextActionService:BindAction("InventoryCancelAction", handleInventoryPlacement, true, Settings.Cancel, Enum.KeyCode.ButtonB)

					ContextActionService:SetTitle("InventoryPlaceAction", "Place")
					ContextActionService:SetTitle("InventoryRotateAction", "Rotate")
					ContextActionService:SetTitle("InventoryCancelAction", "Cancel")
				end)
			end
		end
	end
end

inventoryUpdateEvent.OnClientEvent:Connect(function(inventoryData)
	currentInventory = inventoryData or {}
	populateInventory(currentInventory)
end)

requestInventoryEvent:FireServer()

print("InteractionClient completely initialized - Multiplatform verified")
